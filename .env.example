# Public site URL (for sitemap, auth redirects, JSON-LD; e.g. https://yoursite.com)
# NEXT_PUBLIC_SITE_URL=

# Optional: site-wide business name and contact email (footer, copyright, mailto link)
# Set these in .env.local (and in Vercel env for production). Logged-in visitor name/email comes from Supabase Auth (Google or account profile), not from here.
# NEXT_PUBLIC_SITE_OWNER_NAME=Ryan Realty
# NEXT_PUBLIC_SITE_OWNER_EMAIL=hello@ryanrealty.com

# Supabase (from your project: Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox (from https://account.mapbox.com/access-tokens/)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Spark API (listings feed – https://sparkplatform.com/docs)
SPARK_API_KEY=
# Replication keys must use the replication endpoint (required if you get 403 "use replication.sparkapi.com")
SPARK_API_BASE_URL=https://replication.sparkapi.com/v1
# Optional: for non-replication keys only, omit above and the default is https://sparkapi.com/v1
# Optional: use OAuth instead of Bearer if your MLS requires it
# SPARK_AUTH_SCHEME=OAuth
# Vercel cron (every 15 min) calls GET /api/sync-spark with Authorization: Bearer <CRON_SECRET>
# Set CRON_SECRET in Vercel env so the cron job is authenticated.
CRON_SECRET=
# Optional: secret for manual POST /api/sync-spark (header: x-sync-secret)
# SYNC_SECRET=

# Hero/banner images for city and community pages (Unsplash)
# https://unsplash.com/developers — create an app and use the Access Key
# UNSPLASH_ACCESS_KEY=

# FollowUp Boss CRM — sync/track users when they sign in with Google
# Get API key: Follow Up Boss → Admin → API (use as username, password empty)
# FOLLOWUPBOSS_API_KEY=
# Optional: register your system at https://apps.followupboss.com/system-registration for X-System / X-System-Key
# FOLLOWUPBOSS_SYSTEM=
# FOLLOWUPBOSS_SYSTEM_KEY=
