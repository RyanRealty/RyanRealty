  "description": "Canonical brokerage + creator scrape set for the marketing brain's competitive-intelligence layer. Read by lib/marketing-brain/competitor-recon.ts at runtime. Add a competitor here, not by editing TS unions. Every platform handle starts verified: false — the audit run skips any entry where the relevant platform handle is unverified; verify by hand against the live profile and flip to true before relying on results. Handles can change; re-verify quarterly.",
  "weight_categories": {
    "bend_local": {
      "weight": 2.0,
      "description": "Direct geographic competitors in Bend / Redmond / Sisters / Sunriver. Highest priority in the audit because their content choices directly affect the same seller-lead pool we compete in."
    },
    "national_disruptor": {
      "weight": 1.5,
      "description": "iBuyer and national-platform threats to our seller-lead funnel. Their ad creative + landing pages set the bar Ryan Realty must beat for out-of-state-seller intent."
    },
    "national_content_winner": {
      "weight": 1.5,
      "description": "Top brand-led content brokerages and individual agents whose formats consistently outperform. We are not competing geographically; we are learning format and treatment."
    },
    "pnw_peer": {
      "weight": 1.0,
      "description": "Pacific Northwest brokerages in adjacent metros for benchmarking. Their market is different enough that direct copy will fail, but the platform mechanics translate."
    },
    "local_media": {
      "weight": 0.5,
      "description": "Bend lifestyle + news outlets. Not competitors for listings; included for topic-mining (lifestyle_bend + local_community topics) and to identify what local audiences engage with."
    },
    "adjacent_creator": {
      "weight": 0.5,
      "description": "Mortgage brokers, relocation specialists, regional economists, and lifestyle creators whose content shapes the same seller decision-window we participate in."
    }
  },
